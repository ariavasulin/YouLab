# YouLab Environment Configuration
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit .env to git!

# =============================================================================
# REQUIRED - You must set these
# =============================================================================

# OpenRouter API key - get from https://openrouter.ai/keys
RALPH_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Database password - CHANGE THIS from the default!
DOLT_ROOT_PASSWORD=your-secure-password-here

# OpenWebUI secret key - generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=your-random-secret-here

# =============================================================================
# OPTIONAL - Defaults work for most setups
# =============================================================================

# LLM Model (OpenRouter model ID)
# Options: deepseek/deepseek-v3.2, openai/gpt-4o, google/gemini-pro, etc.
RALPH_OPENROUTER_MODEL=deepseek/deepseek-v3.2

# Honcho (message persistence)
# demo = free hosted demo, production = requires API key
RALPH_HONCHO_ENVIRONMENT=demo
RALPH_HONCHO_WORKSPACE_ID=ralph
# RALPH_HONCHO_API_KEY=hch-v2-your-key  # Only needed for production environment

# Dolt database
RALPH_DOLT_USER=root
RALPH_DOLT_DATABASE=youlab

# Workspace paths
RALPH_USER_DATA_DIR=/data/ralph/users

# Logging
LOG_LEVEL=INFO
